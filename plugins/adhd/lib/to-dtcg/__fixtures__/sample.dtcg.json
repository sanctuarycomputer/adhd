{
  "color": {
    "brand": {
      "surface": {
        "$extensions": {
          "mode": {
            "dark": "{color.gold.900}",
            "light": "{color.gold.100}"
          }
        },
        "$type": "color",
        "$value": "{color.gold.100}"
      }
    },
    "gold": {
      "100": {
        "$type": "color",
        "$value": "#faf0c5"
      },
      "900": {
        "$type": "color",
        "$value": "#3f2909"
      }
    },
    "red": {
      "500": {
        "$type": "color",
        "$value": "#fb2c36"
      }
    }
  },
  "shadow": {
    "2xs": {
      "$type": "shadow",
      "$value": "0 1px rgb(0 0 0 / 0.05)"
    },
    "md": {
      "$type": "shadow",
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
    }
  },
  "spacing": {
    "4": {
      "$type": "dimension",
      "$value": "1rem"
    }
  }
}
